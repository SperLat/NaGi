# Expo Web (single-page-app) fallback for Stablepoint / LiteSpeed.
# Copied verbatim into dist/ by `npx expo export -p web` because anything
# under apps/mobile/public/ is treated as a static asset.
#
# Without this, deep links like nagi.kas.vu/elders/abc 404 — the server
# only has index.html and the JS bundle, so it has to hand every
# unknown path to the SPA and let React Router decide.
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Serve gzipped/brotli pre-compressed assets if the client accepts them.
# LiteSpeed Cache will respect these — no extra plugin config needed.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js|json|svg|woff2?)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|gif|ico|webp|avif)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>
